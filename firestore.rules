rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, role (admin|user), displayName
    
    // Collection: products
    // Fields: name, category, priceStart, image, label, createdAt
    
    // Collection: services
    // Fields: title, description, image, createdAt

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "wisnumahndr321@gmail.com"));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'priceStart', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category is string &&
             data.priceStart is number && data.priceStart >= 0 &&
             data.image is string && data.image.matches("^https?://.*");
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'description', 'image']) &&
             data.title is string && data.title.size() > 0 &&
             data.description is string &&
             data.image is string && data.image.matches("^https?://.*");
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'isActive']) &&
             data.title is string &&
             data.isActive is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && (request.resource.data.role == 'user' || request.resource.data.email == "wisnumahndr321@gmail.com" && request.resource.data.role == "admin")) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidEvent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true; // Public catalog
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true; // Public services
      allow create, update: if isAdmin() && isValidService(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
